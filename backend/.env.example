# VNPAY Configuration Example
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
APP_URL=http://localhost:3000

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=that_clinic
MYSQL_DISABLED=false

# VNPAY Configuration
# Get these values from https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=THATCLINIC
VNPAY_HASH_SECRET=your_secret_key_here

# For testing: set to true to disable database (API-only mode)
# MYSQL_DISABLED=true
